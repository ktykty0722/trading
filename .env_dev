# =====================================================
# 한국투자증권 (KIS) API 설정
# KIS_USE_MOCK=true  → 모의투자 appkey/secret/계좌 사용
# KIS_USE_MOCK=false → 실제투자 appkey/secret/계좌 사용
# =====================================================
KIS_USE_MOCK=true

# 모의투자 설정 (https://openapi.koreainvestment.com 에서 발급)
KIS_BASE_URL=https://openapivts.koreainvestment.com:29443
KIS_MOCK_APPKEY=
KIS_MOCK_APPSECRET=
KIS_MOCK_CANO=

# 실제투자 설정
KIS_REAL_URL=https://openapi.koreainvestment.com:9443
KIS_REAL_APPKEY=
KIS_REAL_APPSECRET=
KIS_REAL_CANO=

KIS_ACNT_PRDT_CD=01
TR_ID=VTTC8434R

# =====================================================
# Supabase
# =====================================================
SUPABASE_URL=
SUPABASE_KEY=

# =====================================================
# 외부 API 키
# =====================================================
# FRED 경제 데이터 API (https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# AlphaVantage 뉴스 감성 분석 (https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_API_KEY=

# Anthropic Claude API (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# =====================================================
# 서버 설정
# =====================================================
DEBUG=false

# CORS 허용 출처 (쉼표로 구분, 운영환경에서는 실제 도메인 지정)
# 예) CORS_ORIGINS=https://yourdomain.com,http://localhost:3000
CORS_ORIGINS=*

# =====================================================
# Telegram Bot (Phase 2에서 설정)
# =====================================================
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=