# 한국투자증권 API 설정
# 모의투자: KIS_USE_MOCK=true → 모의투자 appkey/secret/계좌 사용
# 실제투자: KIS_USE_MOCK=false → 실제투자 appkey/secret/계좌 사용
KIS_USE_MOCK=true

# 모의투자 설정
KIS_BASE_URL=https://openapivts.koreainvestment.com:29443
KIS_MOCK_APPKEY=
KIS_MOCK_APPSECRET=
KIS_MOCK_CANO=

# 실제투자 설정
KIS_REAL_URL=https://openapi.koreainvestment.com:9443
KIS_REAL_APPKEY=
KIS_REAL_APPSECRET=
KIS_REAL_CANO=

KIS_ACNT_PRDT_CD=01
TR_ID=VTTC8434R

# Supabase 설정 (코드에서 가져온 실제 값으로 수정)
# SUPABASE_URL=https://kygqxmuwhwfsywkdvadb.supabase.co
SUPABASE_URL=
SUPABASE_KEY=

# AlphaVantage API 키 (주식 추천 서비스에서 사용)
ALPHA_VANTAGE_API_KEY=

# 기타 환경 설정
DEBUG=true

# Claude API 키
ANTHROPIC_API_KEY=